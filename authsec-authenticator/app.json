{
  "expo": {
    "name": "AuthSec Authenticator",
    "slug": "authsec-authenticator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./appicon.png",
    "scheme": "authsec",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "YOUR_EAS_PROJECT_ID"
      }
    },
    "splash": {
      "image": "./logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.authsec.app",
      "buildNumber": "6",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSFaceIDUsageDescription": "We use Face ID to securely authenticate and protect your account.",
        "NSCameraUsageDescription": "AuthSec Authenticator needs camera access to scan QR codes for setting up TOTP authentication. No photos or videos are recorded or stored."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./appicon.png",
        "backgroundColor": "#FFFFFF"
      },
      "versionCode": 6,
      "package": "com.authsec.app",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "favicon": "./appicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./appicon.png",
          "color": "#2196F3"
        }
      ],
      "expo-web-browser"
    ]
  }
}
